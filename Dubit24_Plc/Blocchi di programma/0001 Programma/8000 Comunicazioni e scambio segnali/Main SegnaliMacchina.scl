FUNCTION "Main SegnaliMacchina" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1

BEGIN
	
	
	"GestSegnaliMacchina"(K_SegnaleMacchina:= 0,
	                      K_ComunicazioneS7:= 0,
	                      K_TipoComunicazione:="K_TipoComunicazione_GetPut",
	                      K_TipoLetturaScrittura:="K_TipoLetturaScrittura_LetturaScrittura");
	
	"Main consensi"();
	
END_FUNCTION

