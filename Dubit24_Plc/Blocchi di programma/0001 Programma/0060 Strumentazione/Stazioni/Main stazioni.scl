FUNCTION "Main stazioni" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_TEMP 
      CounterStazioni : Int;
      CounterDestinazioni : Int;
      K_Analogica : Int;
      DisabilitaStazioneAdditiva : Bool;
      CondizioniTimeout : Bool;
   END_VAR


BEGIN
	IF "Percorso".Funzioni.Inizializza THEN
	    FOR #CounterStazioni := 0 TO "K_NumStazione" DO
	        FOR #CounterDestinazioni := 0 TO "K_NumStazione" DO
	            "Percorso".S[#CounterStazioni].Destinazione[#CounterDestinazioni].IN.Possibile := False;
	        END_FOR;
	        "Percorso".S[#CounterStazioni].Hmi.Diagnostica.TroppoPieno :=
	        "Percorso".S[#CounterStazioni].Dati.InvioAdditivo.Abilitazione :=
	        "Percorso".S[#CounterStazioni].Dati.InvioAdditivo.Attiva :=
	        "Percorso".S[#CounterStazioni].Dati.RicezioneAdditivo.Attiva :=
	        "Percorso".S[#CounterStazioni].Dati.GestionePrioritàAttiva.DaDestinazione :=
	        "Percorso".S[#CounterStazioni].Dati.GestionePrioritàAttiva.DaSorgente :=
	        "Percorso".S[#CounterStazioni].Dati.AlmenoUnaDestinazioneProgettata :=
	        "Percorso".S[#CounterStazioni].Dati.AlmenoUnaSorgenteProgettata :=
	        "Percorso".S[#CounterStazioni].Prm.AbilitazionePriorità.SuEstrazioni :=
	        "Percorso".S[#CounterStazioni].Prm.AbilitazionePriorità.SugliArrivi :=
	        "Percorso".S[#CounterStazioni].Prm.IgnoraDestinazione :=
	        "Percorso".S[#CounterStazioni].Prm.ByPassChiamataDestinazione := False;
	        "Percorso".S[#CounterStazioni].Dati.K_StazioneDestinazione :=
	        "Percorso".S[#CounterStazioni].Dati.InvioAdditivo.K_StazioneRiferimento1 :=
	        "Percorso".S[#CounterStazioni].Dati.RicezioneAdditivo.K_StazioneRiferimento := 0;
	        "Percorso".S[#CounterStazioni].IN.SorgenteNonPronta :=
	        "Percorso".S[#CounterStazioni].IN.LivelloDestinazioneSuperiorePriorità :=
	        "Percorso".S[#CounterStazioni].IN.LivelloSorgenteInferiorePriorità := False;
	    END_FOR;
	    "Percorso".Hmi.AggiornaConfigurazione := True;
	    "Percorso".Funzioni.Inizializza := False;
	END_IF;
END_FUNCTION

